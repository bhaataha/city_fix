# ============================================
# CityFix Environment Configuration
# ============================================

# Database
DATABASE_URL="postgresql://cityfix:cityfix_dev@localhost:5432/cityfix?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-me-in-production-use-64-char-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-refresh-secret-64-chars"
JWT_REFRESH_EXPIRES_IN="7d"

# MinIO / S3
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="cityfix_minio"
MINIO_SECRET_KEY="cityfix_minio_secret"
MINIO_BUCKET="cityfix-uploads"
MINIO_USE_SSL=false

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN="pk.your-mapbox-token-here"

# Email (Resend)
RESEND_API_KEY="re_your-resend-key"
EMAIL_FROM="noreply@cityfix.co.il"

# App
API_PORT=4100
WEB_PORT=3100
NODE_ENV=development
